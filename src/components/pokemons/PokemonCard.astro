---
interface Props {
	name: string;
	url: string;
	isBig?: boolean;
}
const { name, url, isBig = false } = Astro.props;
const id = url.split("/").at(-2);
const imageURL = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;
---

<a href={`/pokemons/${name}`} class:list={[`rounded flex flex-col items-center justify-center gap-2 shadow-md p-4`, {'border' : !isBig}]}>
	<img transition:name={`${name}-image`} src={imageURL} alt={name}
		class:list={[
			{
				'w-60 h-60' : isBig, 
				'w-16 h-16' : !isBig
			},
			]}
	/>
	<span class:list={
		[
			'capitalize',
			{'text-4xl': isBig}
		]
	} >#{id} {name}</span>
</a>