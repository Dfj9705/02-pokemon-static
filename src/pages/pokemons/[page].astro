---
import type { GetStaticPaths } from "astro";
import PokemonCard from "@components/pokemons/PokemonCard.astro";
import type { PokemonListResponse } from "@interfaces/pokemon-list.response";
import Layout from "@layouts/main.astro";


export const getStaticPaths = (async({paginate}) => {
    const resp = await fetch("https://pokeapi.co/api/v2/pokemon?limit=151");
    
    const {results} = await resp.json() as PokemonListResponse;
    
    return paginate(results, { pageSize: 20 });
}) satisfies GetStaticPaths;

const title = "Home";
const {page} = Astro.props;
---

<Layout title={title}>
	<h1 class="text-3xl">Listado de Pokemons</h1>
	<hr />
	<section
		aria-label="listado de pokemons"
		class="grid grid-cols-1 sm:grid-cols-4 md:grid-cols-5 gap-4 mt-5"
	>
		{page.data.map(({name, url}) => (
			<PokemonCard name={name} url={url} />
		))}
	</section>
	<section class="flex mt-10 gap-2 items-center justify-between">
		<a 
			class:list={[
				"btn",
				{
					disabled: !page.url.prev
				}
			]}
		href={page.url.prev}>Anteriores</a>
		<a 
			class:list={[
				"btn",
				{
					disabled: !page.url.next
				}
			]}
			href={page.url.next}>Siguientes</a>
		<div class="flex flex-1">

		</div>
		<span>Pagina {page.currentPage} de {page.lastPage}</span>
	</section>
</Layout>



<style>
	@import url("../../styles/global.css");
	.btn{
		@apply bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-md;
	}

	.disabled{
		@apply bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-md cursor-not-allowed;
	}
</style>
